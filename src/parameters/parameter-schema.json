{
  "schema_version": "2.0.0",
  "description": "Finalized S.W.E.I Parameter Schema - Staged Architecture v2",
  "parameter": {
    "type": "object",
    "properties": {
      "id": { "type": "string" },
      "category": { "type": "string" },
      "subcategory": { "type": "string" },
      "version": { "type": "integer" },
      "status": { "enum": ["stable", "experimental", "deprecated"] },
      "intent_type": { "enum": ["atomic", "composite", "router", "tool", "memory", "reasoning"] },
      "priority": { "type": "integer" },
      "triggers": { "type": "array", "items": { "type": "string" } },
      "activation_threshold": { "type": "number" },
      "routing_strategy": { "enum": ["direct", "multi_step", "tool_augmented", "hybrid"] },
      "requires_context": { "type": "boolean" },
      "requires_memory": { "type": "boolean" },
      "requires_tools": { "type": "boolean" },
      "tool_dependencies": { "type": "array", "items": { "type": "string" } },
      "clarifying_questions": { "type": "array" },
      "response_template": { "type": "string" },
      "fallback_intents": { "type": "array", "items": { "type": "string" } },
      "examples": { "type": "array" },
      "failure_cases": { "type": "array" },
      "confidence": { "type": "number" },
      "success_rate": { "type": "number" },
      "failure_rate": { "type": "number" },
      "execution_cost": { "type": "number" },
      "token_cost": { "type": "number" },
      "reward_score": { "type": "number" },
      "penalty_score": { "type": "number" },
      "source": { "type": "string" },
      "created": { "type": "string" },
      "last_updated": { "type": "string" }
    }
  }
}